<script>
// ─── CURSOR ───
const cur = document.getElementById('cursor');
const ring = document.getElementById('cursor-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px'});
function animRing(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(animRing)}
animRing();

// ─── CANVAS ───
const canvas=document.getElementById('bg');
const ctx=canvas.getContext('2d');
let pts=[];
function resizeCv(){canvas.width=window.innerWidth;canvas.height=window.innerHeight}
function makePts(){pts=[];const n=Math.min(60,Math.floor(window.innerWidth/18));for(let i=0;i<n;i++)pts.push({x:Math.random()*canvas.width,y:Math.random()*canvas.height,vx:(Math.random()-.5)*.35,vy:(Math.random()-.5)*.35,r:Math.random()*1.2+.4,a:Math.random()*.4+.1,c:Math.random()>.5?'59,130,246':'124,58,237'})}
function drawCv(){ctx.clearRect(0,0,canvas.width,canvas.height);pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0)p.x=canvas.width;if(p.x>canvas.width)p.x=0;if(p.y<0)p.y=canvas.height;if(p.y>canvas.height)p.y=0;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=`rgba(${p.c},${p.a})`;ctx.fill()});pts.forEach((a,i)=>pts.slice(i+1).forEach(b=>{const d=Math.hypot(a.x-b.x,a.y-b.y);if(d<90){ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);ctx.strokeStyle=`rgba(59,130,246,${.06*(1-d/90)})`;ctx.lineWidth=.5;ctx.stroke()}}));requestAnimationFrame(drawCv)}
resizeCv();makePts();drawCv();
window.addEventListener('resize',()=>{resizeCv();makePts()});

// ─── LOADER ───
const loaderMessages=['INITIALIZING SYSTEMS...','LOADING GAME DATA...','CONNECTING TO SERVERS...','CALIBRATING ANTI-CHEAT...','ENTERING THE ARENA...'];
let lmi=0;
const lmInterval=setInterval(()=>{lmi++;if(lmi<loaderMessages.length)document.getElementById('loaderCode').textContent=loaderMessages[lmi];},400);
setTimeout(()=>{clearInterval(lmInterval);document.getElementById('loader').classList.add('hidden');initCounters();},2200);

// ─── NAVBAR ───
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('scrolled',scrollY>40));
function toggleMenu(){document.getElementById('navLinks').classList.toggle('open')}

// ─── PAGE SYSTEM ───
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  document.querySelectorAll('.nav-links a').forEach(a=>a.classList.toggle('active',a.dataset.page===id));
  window.scrollTo(0,0);
  setTimeout(()=>document.querySelectorAll('.fade-up').forEach(el=>observer.observe(el)),50);
  if(id==='leaderboard')renderLb('day');
  if(id==='matches')renderMatches('fn');
  if(id==='shop')renderShop('all');
  if(id==='tournaments')renderTourneys();
}

// ─── OBSERVER ───
const observer=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');if(e.target.querySelector('[data-target]'))e.target.querySelectorAll('[data-target]').forEach(animCount)}}),{threshold:.1});
setTimeout(()=>document.querySelectorAll('.fade-up').forEach(el=>observer.observe(el)),2300);

// ─── COUNTERS ───
function animCount(el){const t=parseInt(el.dataset.target.replace(/,/g,''));let c=0;const s=t/(2000/16);const iv=setInterval(()=>{c=Math.min(c+s,t);el.textContent=Math.floor(c).toLocaleString('fr-FR')+'+';if(c>=t)clearInterval(iv)},16)}
function initCounters(){document.querySelectorAll('[data-target]').forEach(animCount)}

// ─── MODAL ───
function openModal(){document.getElementById('authModal').classList.add('open')}
function closeModal(){document.getElementById('authModal').classList.remove('open')}
function switchAuthTab(tab,btn){document.querySelectorAll('.modal-tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active')}
function fakeLogin(){closeModal();notify('Connexion réussie ! Bienvenue sur XENOVRA 🎮')}
document.getElementById('authModal').addEventListener('click',e=>{if(e.target===document.getElementById('authModal'))closeModal()});

// ─── NOTIFY ───
function notify(msg,icon='✅'){
  document.getElementById('notifText').textContent=msg;
  document.getElementById('notifIcon').textContent=icon;
  const n=document.getElementById('notif');
  n.classList.add('show');
  setTimeout(()=>n.classList.remove('show'),3000);
}

// ─── DATA ───
const fnModes=[{icon:'🥊',name:'Boxfight',players:'1v1 · 2v2 · 3v3 · 4v4'},{icon:'🌀',name:'Zone Wars',players:'1v1 · 2v2 · 4v4'},{icon:'🏗️',name:'Build Fight',players:'1v1 · 2v2'},{icon:'🎯',name:'Realistic',players:'1v1 · 2v2 · 3v3'},{icon:'🧩',name:'Piece Control',players:'1v1'},{icon:'🚫',name:'Zero Build',players:'1v1 · 2v2 · 4v4'}];
const crModes=[{icon:'⚔️',name:'Battle',players:'1v1'},{icon:'🔄',name:'Duel',players:'1v1'},{icon:'📋',name:'Draft',players:'1v1'},{icon:'🌟',name:'Mega Draft',players:'1v1'},{icon:'3️⃣',name:'Triple Draft',players:'1v1'},{icon:'🪞',name:'Mirror',players:'1v1'},{icon:'🏈',name:'Touchdown',players:'1v1 · 2v2'},{icon:'⚡',name:'x7 Elixir',players:'1v1'},{icon:'👥',name:'2v2 Touchdown',players:'2v2'}];
const openMatchesData=[
  {id:1,game:'fn',icon:'⚡',gameName:'Fortnite',mode:'Boxfight 1v1',p1:{name:'NovaBeast',color:'#3b82f6'},p2:null,bet:500,status:'open'},
  {id:2,game:'cr',icon:'👑',gameName:'Clash Royale',mode:'Draft 1v1',p1:{name:'CRKingdom',color:'#7c3aed'},p2:{name:'RoyalCrush',color:'#a78bfa'},bet:1200,status:'live'},
  {id:3,game:'fn',icon:'⚡',gameName:'Fortnite',mode:'Zone Wars 2v2',p1:{name:'ProBuilderX',color:'#06b6d4'},p2:null,bet:800,status:'open'},
  {id:4,game:'cr',icon:'👑',gameName:'Clash Royale',mode:'Mega Draft 1v1',p1:{name:'GoblinQueen',color:'#10b981'},p2:null,bet:350,status:'open'},
  {id:5,game:'fn',icon:'⚡',gameName:'Fortnite',mode:'Realistic 3v3',p1:{name:'TeamAlpha',color:'#f59e0b'},p2:{name:'TeamBeta',color:'#ef4444'},bet:2000,status:'live'},
  {id:6,game:'fn',icon:'⚡',gameName:'Fortnite',mode:'Zero Build 1v1',p1:{name:'StealthFN',color:'#8b5cf6'},p2:null,bet:600,status:'open'},
];
const lbData={
  day:[{name:'XenoProFN',tag:'#1024',coins:8450,wins:12,ratio:92,color:'#3b82f6'},{name:'CRMaster99',tag:'#0887',coins:6200,wins:9,ratio:88,color:'#7c3aed'},{name:'ZeroGravity',tag:'#3341',coins:5800,wins:11,ratio:85,color:'#06b6d4'},{name:'NovaBeast',tag:'#7712',coins:4900,wins:8,ratio:80,color:'#10b981'},{name:'RoyalCrush',tag:'#5521',coins:3700,wins:7,ratio:77,color:'#f59e0b'},{name:'StealthFN',tag:'#9904',coins:3200,wins:6,ratio:75,color:'#8b5cf6'},{name:'GoblinKing',tag:'#4413',coins:2800,wins:5,ratio:71,color:'#ef4444'},{name:'ProBuilderX',tag:'#2267',coins:2400,wins:4,ratio:68,color:'#ec4899'}],
  week:[{name:'CRMaster99',tag:'#0887',coins:42000,wins:67,ratio:91,color:'#7c3aed'},{name:'XenoProFN',tag:'#1024',coins:38500,wins:58,ratio:88,color:'#3b82f6'},{name:'NovaBeast',tag:'#7712',coins:31000,wins:49,ratio:84,color:'#10b981'},{name:'ZeroGravity',tag:'#3341',coins:27500,wins:44,ratio:82,color:'#06b6d4'},{name:'RoyalCrush',tag:'#5521',coins:24000,wins:40,ratio:79,color:'#f59e0b'},{name:'StealthFN',tag:'#9904',coins:21000,wins:36,ratio:76,color:'#8b5cf6'},{name:'GoblinKing',tag:'#4413',coins:18500,wins:31,ratio:73,color:'#ef4444'},{name:'ProBuilderX',tag:'#2267',coins:15000,wins:25,ratio:70,color:'#ec4899'}],
  month:[{name:'ZeroGravity',tag:'#3341',coins:180000,wins:280,ratio:90,color:'#06b6d4'},{name:'XenoProFN',tag:'#1024',coins:165000,wins:255,ratio:87,color:'#3b82f6'},{name:'CRMaster99',tag:'#0887',coins:154000,wins:240,ratio:86,color:'#7c3aed'},{name:'NovaBeast',tag:'#7712',coins:142000,wins:220,ratio:83,color:'#10b981'},{name:'StealthFN',tag:'#9904',coins:128000,wins:198,ratio:80,color:'#8b5cf6'},{name:'RoyalCrush',tag:'#5521',coins:115000,wins:178,ratio:77,color:'#f59e0b'},{name:'ProBuilderX',tag:'#2267',coins:98000,wins:152,ratio:74,color:'#ec4899'},{name:'GoblinKing',tag:'#4413',coins:87000,wins:134,ratio:71,color:'#ef4444'}]
};
const shopItems=[
  {cat:'avatar',icon:'🦊',name:'Fox Elite Avatar',desc:'Avatar renard futuriste exclusif',price:800,rarity:'epic',rarityClass:'rarity-epic',rarityLabel:'r-epic',rarityText:'ÉPIQUE'},
  {cat:'titre',icon:'⚡',name:'Titre "Thunder God"',desc:'Affiche ton titre légendaire en jeu',price:1200,rarity:'legendary',rarityClass:'rarity-legendary',rarityLabel:'r-legendary',rarityText:'LÉGENDAIRE'},
  {cat:'badge',icon:'🏅',name:'Badge Fortnite Pro',desc:'Badge exclusif joueurs Fortnite vétérans',price:600,rarity:'rare',rarityClass:'rarity-rare',rarityLabel:'r-rare',rarityText:'RARE'},
  {cat:'effet',icon:'✨',name:'Effet Particules Néon',desc:'Aura de particules violettes sur ton profil',price:1500,rarity:'legendary',rarityClass:'rarity-legendary',rarityLabel:'r-legendary',rarityText:'LÉGENDAIRE'},
  {cat:'cadre',icon:'🖼',name:'Cadre Cyber Blue',desc:'Cadre de profil holographique bleu',price:400,rarity:'rare',rarityClass:'rarity-rare',rarityLabel:'r-rare',rarityText:'RARE'},
  {cat:'avatar',icon:'🐺',name:'Wolf Alpha Avatar',desc:'Avatar loup alpha dominateur',price:500,rarity:'rare',rarityClass:'rarity-rare',rarityLabel:'r-rare',rarityText:'RARE'},
  {cat:'titre',icon:'👑',name:'Titre "Clash King"',desc:'Titre prestige pour les maîtres CR',price:1000,rarity:'epic',rarityClass:'rarity-epic',rarityLabel:'r-epic',rarityText:'ÉPIQUE'},
  {cat:'badge',icon:'🛡️',name:'Badge Fair Play',desc:'Récompense les joueurs respectueux',price:200,rarity:'common',rarityClass:'rarity-common',rarityLabel:'r-common',rarityText:'COMMUN'},
  {cat:'effet',icon:'🌊',name:'Effet Vague Cyan',desc:'Ondulation cyan autour de ton avatar',price:900,rarity:'epic',rarityClass:'rarity-epic',rarityLabel:'r-epic',rarityText:'ÉPIQUE'},
  {cat:'cadre',icon:'🔥',name:'Cadre Inferno',desc:'Cadre enflammé pour les warriors',price:700,rarity:'epic',rarityClass:'rarity-epic',rarityLabel:'r-epic',rarityText:'ÉPIQUE'},
  {cat:'avatar',icon:'🤖',name:'Xeno Bot Avatar',desc:'Avatar robot exclusif XENOVRA',price:300,rarity:'common',rarityClass:'rarity-common',rarityLabel:'r-common',rarityText:'COMMUN'},
  {cat:'badge',icon:'⭐',name:'Badge Top 100',desc:'Pour les joueurs classés Top 100',price:1800,rarity:'legendary',rarityClass:'rarity-legendary',rarityLabel:'r-legendary',rarityText:'LÉGENDAIRE'},
];
const tourneyData=[
  {game:'fn',banner:'tc-banner-fn',emoji:'⚡',status:'open',statusClass:'tc-open',statusText:'INSCRIPTIONS',name:'XENOVRA Fortnite Cup #8',mode:'Zero Build 1v1',prize:'25 000 XC',players:'64/128',date:'15 Jan 2025',btnClass:'tc-join-open',btnText:'S\'inscrire →'},
  {game:'cr',banner:'tc-banner-cr',emoji:'👑',status:'open',statusClass:'tc-open',statusText:'INSCRIPTIONS',name:'Clash Royale Grand Prix',mode:'Draft 1v1',prize:'18 000 XC',players:'32/64',date:'18 Jan 2025',btnClass:'tc-join-open',btnText:'S\'inscrire →'},
  {game:'fn',banner:'tc-banner-fn',emoji:'⚡',status:'soon',statusClass:'tc-soon',statusText:'BIENTÔT',name:'Fortnite Boxfight Elite',mode:'Boxfight 2v2',prize:'40 000 XC',players:'0/32',date:'22 Jan 2025',btnClass:'tc-join-soon',btnText:'Rappel →'},
  {game:'cr',banner:'tc-banner-cr',emoji:'👑',status:'open',statusClass:'tc-open',statusText:'INSCRIPTIONS',name:'CR Mega Draft Masters',mode:'Mega Draft',prize:'12 000 XC',players:'18/32',date:'20 Jan 2025',btnClass:'tc-join-open',btnText:'S\'inscrire →'},
  {game:'fn',banner:'tc-banner-fn',emoji:'⚡',status:'ended',statusClass:'tc-ended',statusText:'TERMINÉ',name:'XENOVRA Fortnite Cup #7',mode:'Zone Wars 1v1',prize:'20 000 XC',players:'128/128',date:'8 Jan 2025',btnClass:'tc-join-ended',btnText:'Voir résultats'},
  {game:'cr',banner:'tc-banner-cr',emoji:'👑',status:'soon',statusClass:'tc-soon',statusText:'BIENTÔT',name:'CR 2v2 Touchdown Cup',mode:'2v2 Touchdown',prize:'30 000 XC',players:'0/16',date:'28 Jan 2025',btnClass:'tc-join-soon',btnText:'Rappel →'},
];
const liveMatchesPreview=[
  {icon:'⚡',iconClass:'fn-icon',game:'Fortnite · Boxfight 1v1',bet:500,p1:'XenoPro',p2:'GhostFN'},
  {icon:'👑',iconClass:'cr-icon-bg',game:'Clash Royale · Draft',bet:1200,p1:'CRMaster',p2:'RoyalX'},
  {icon:'⚡',iconClass:'fn-icon',game:'Fortnite · Zone Wars 2v2',bet:800,p1:'TeamA',p2:'TeamB'},
];

// ─── RENDER FUNCTIONS ───
function renderLiveMatchesPreview(){
  document.getElementById('liveMatchesList').innerHTML=liveMatchesPreview.map(m=>`
    <div class="match-item">
      <div class="match-game-icon ${m.iconClass}">${m.icon}</div>
      <div class="match-info">
        <div class="match-name">${m.p1} vs ${m.p2}</div>
        <div class="match-meta">${m.game}</div>
      </div>
      <div class="match-bet">
        <div class="match-bet-amount">⚡${m.bet}</div>
        <div class="match-bet-label">XCoins</div>
        <div class="match-status-live"><span style="width:5px;height:5px;background:var(--green);border-radius:50%;display:inline-block;animation:pulse 1.5s infinite"></span> LIVE</div>
      </div>
    </div>
  `).join('')}

let currentGame='fn';
function switchGame(g,btn){
  currentGame=g;
  document.querySelectorAll('.gtab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderMatches(g);
}
function renderMatches(g){
  const modes=g==='fn'?fnModes:crModes;
  document.getElementById('modesGrid').innerHTML=modes.map(m=>`
    <div class="mode-card ${g}-mode" onclick="notify('Mode ${m.name} sélectionné !')">
      <span class="mode-icon">${m.icon}</span>
      <div class="mode-name">${m.name}</div>
      <div class="mode-players">${m.players}</div>
    </div>
  `).join('');
  const filtered=openMatchesData.filter(m=>g==='fn'?m.game==='fn':m.game==='cr');
  document.getElementById('openMatches').innerHTML=filtered.map(m=>`
    <div class="open-match-card">
      <div class="omc-top">
        <div class="omc-game">
          <div class="omc-game-icon ${m.game==='fn'?'fn-icon':'cr-icon-bg'}">${m.icon}</div>
          <div>
            <div class="omc-game-name">${m.gameName}</div>
            <div class="omc-game-mode">${m.mode}</div>
          </div>
        </div>
        <div class="omc-status ${m.status==='live'?'status-live':'status-open'}">${m.status==='live'?'🔴 LIVE':'🟢 OUVERT'}</div>
      </div>
      <div class="omc-players">
        <div class="player-avatar" style="background:linear-gradient(135deg,${m.p1.color}44,${m.p1.color}22);color:${m.p1.color}">${m.p1.name[0]}</div>
        <span style="font-size:.82rem;color:#fff;font-weight:600">${m.p1.name}</span>
        ${m.p2?`<span class="vs-label">VS</span><div class="player-avatar" style="background:linear-gradient(135deg,${m.p2.color}44,${m.p2.color}22);color:${m.p2.color}">${m.p2.name[0]}</div><span style="font-size:.82rem;color:#fff;font-weight:600">${m.p2.name}</span>`:'<span class="vs-label">VS</span><div class="player-avatar" style="background:rgba(255,255,255,.05);border:1px dashed rgba(255,255,255,.2);color:var(--muted2)">?</div><span style="font-size:.78rem;color:var(--muted2)">En attente...</span>'}
      </div>
      <div class="omc-bet"><span>Mise</span><span class="omc-bet-amount">⚡ ${m.bet.toLocaleString('fr-FR')} XC</span></div>
      <button class="join-btn" onclick="joinMatch(${m.id})">${m.status==='live'?'👁️ Spectateur':'⚔️ Rejoindre'}</button>
    </div>
  `).join('')}
function joinMatch(id){notify(`Match #${id} rejoint ! Bon courage ⚔️`,'⚔️')}
function showCreateMatch(){notify('Création de match bientôt disponible !','🔨')}

function renderLb(period){
  const data=lbData[period];
  const ranks=['gold','silver','bronze'];
  const icons=['🥇','🥈','🥉'];
  document.getElementById('lbRows').innerHTML=data.map((p,i)=>`
    <div class="lb-row ${i<3?'top'+(i+1):''}">
      <div class="lb-rank ${i<3?ranks[i]:'normal'}">${i<3?icons[i]:i+1}</div>
      <div class="lb-player">
        <div class="lb-avatar" style="background:linear-gradient(135deg,${p.color}44,${p.color}22);color:${p.color};border:1px solid ${p.color}33">${p.name[0]}</div>
        <div><div class="lb-pname">${p.name}</div><div class="lb-ptag">${p.tag}</div></div>
      </div>
      <div class="lb-coins">⚡ ${p.coins.toLocaleString('fr-FR')}</div>
      <div class="lb-wins">${p.wins}W</div>
      <div class="lb-ratio">${p.ratio}%</div>
    </div>
  `).join('')}
function switchLb(p,btn){document.querySelectorAll('.lb-tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active');renderLb(p)}

let currentShopFilter='all';
function filterShop(f,btn){
  currentShopFilter=f;
  document.querySelectorAll('.shop-cat').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderShop(f);
}
function renderShop(f){
  const items=f==='all'?shopItems:shopItems.filter(i=>i.cat===f);
  document.getElementById('shopGrid').innerHTML=items.map(i=>`
    <div class="shop-item">
      <div class="shop-item-img ${i.rarityClass}">
        <span class="shop-rarity ${i.rarityLabel}">${i.rarityText}</span>
        <span style="position:relative;z-index:1">${i.icon}</span>
      </div>
      <div class="shop-item-body">
        <div class="shop-item-name">${i.name}</div>
        <div class="shop-item-desc">${i.desc}</div>
        <div class="shop-item-footer">
          <div class="shop-price">⚡ ${i.price.toLocaleString('fr-FR')} XC</div>
          <button class="shop-buy-btn" onclick="buyItem('${i.name}',${i.price})">Acheter</button>
        </div>
      </div>
    </div>
  `).join('')}
function buyItem(name,price){
  const coins=parseInt(document.getElementById('navCoins').textContent.replace(/\s/g,''));
  if(coins>=price){
    document.getElementById('navCoins').textContent=(coins-price).toLocaleString('fr-FR');
    notify(`"${name}" acheté ! ✨`,'🛍️');
  } else notify(`XCoins insuffisants ! Il te manque ${(price-coins).toLocaleString('fr-FR')} XC`,'❌');
}

function renderTourneys(){
  document.getElementById('tourneyGrid').innerHTML=tourneyData.map(t=>`
    <div class="tourney-card">
      <div class="tc-banner ${t.banner}">
        <div class="tc-banner-emoji">${t.emoji}</div>
        <span class="tc-status-badge ${t.statusClass}">${t.statusText}</span>
      </div>
      <div class="tc-body">
        <div class="tc-game">${t.game==='fn'?'⚡ Fortnite':'👑 Clash Royale'} · ${t.mode}</div>
        <div class="tc-name">${t.name}</div>
        <div class="tc-info">
          <div class="tc-info-item"><div class="tc-info-label">Prize Pool</div><div class="tc-info-val tc-prize">⚡ ${t.prize}</div></div>
          <div class="tc-info-item"><div class="tc-info-label">Joueurs</div><div class="tc-info-val">${t.players}</div></div>
          <div class="tc-info-item"><div class="tc-info-label">Date</div><div class="tc-info-val">${t.date}</div></div>
          <div class="tc-info-item"><div class="tc-info-label">Format</div><div class="tc-info-val">Bracket</div></div>
        </div>
        <button class="tc-join-btn ${t.btnClass}" onclick="joinTourney('${t.name}')">${t.btnText}</button>
      </div>
    </div>
  `).join('')}
function joinTourney(name){notify(`Inscription à "${name}" confirmée 🏆`,'🏆')}

// ─── INIT ───
renderLiveMatchesPreview();
</script>
</body>
</html>
